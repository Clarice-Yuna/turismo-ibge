generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url       = env("DATABASE_URL")
}


model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizAttempts QuizAttempt[]
}

// Tab 1 - Estabelecimentos por tipo e UF
model EstabPorTipo {
  id            String @id @default(cuid())
  uf            String
  total         Int
  hoteis        Int
  apartHoteis   Int
  pousadas      Int
  moteis        Int
  pensoes       Int
  hostels       Int
  outros        Int
}

// Tab 2 - Estabelecimentos por grupos de UHs
model EstabPorGrupoUH {
  id       String @id @default(cuid())
  uf       String
  total    Int
  ate4     Int
  de5a9    Int
  de10a19  Int
  de20a29  Int
  de30a49  Int
  de50a99  Int
  de100mais Int
}

// Tab 3 - Unidades habitacionais e leitos por UF
model UHLeitosUF {
  id          String @id @default(cuid())
  uf          String
  uhTotal     Int
  uhAdaptadas Int
  leitosTotal Int
  leitosSimples Int
  leitosDuplos  Int
}

// Tab 4 - Capitais
model Capitais {
  id            String @id @default(cuid())
  capital       String
  estabelecimentos Int
  uhTotal       Int
  uhAdaptadas   Int
  leitosTotal   Int
  leitosSimples Int
  leitosDuplos  Int
}

// Tab 6 - Categorias dos estabelecimentos
model EstabPorCategoria {
  id       String @id @default(cuid())
  uf       String
  total    Int
  luxo     Int
  superior Int
  turistico Int
  economico Int
  simples  Int
}

// Tab 7 - Características (Independente, Cadeia nacional, Cadeia internacional)
model EstabPorCaracteristica {
  id              String @id @default(cuid())
  uf              String
  total           Int
  independentes   Int
  cadeiaNacional  Int
  cadeiaInternacional Int
}

// Tab 10 - Localização
model EstabPorLocalizacao {
  id             String @id @default(cuid())
  uf             String
  total          Int
  urbanaCentro   Int
  urbanaFora     Int
  orlaMaritima   Int
  zonaRural      Int
}

// Quiz system
model QuizCategory {
  id          String @id @default(cuid())
  name        String
  description String
  icon        String
  color       String
  order       Int    @default(0)

  questions    QuizQuestion[]
  quizAttempts QuizAttempt[]
}

model QuizQuestion {
  id            String @id @default(cuid())
  categoryId    String
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  explanation   String
  difficulty    String @default("medium")
  order         Int    @default(0)

  category QuizCategory @relation(fields: [categoryId], references: [id])
}

model QuizAttempt {
  id             String @id @default(cuid())
  userId         String
  categoryId     String
  score          Int
  totalQuestions Int
  timeTaken      Int    @default(0)
  answers        String
  completedAt    DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id])
  category QuizCategory @relation(fields: [categoryId], references: [id])
}

model Curiosity {
  id        String @id @default(cuid())
  title     String
  content   String
  category  String
  icon      String
  source    String?
  order     Int    @default(0)
}
