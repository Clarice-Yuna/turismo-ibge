# ============================================
# Turismo IBGE 2016 - Variáveis de Ambiente
# ============================================
# COPIE este arquivo para .env e preencha com seus valores reais:
#   cp .env.example .env
#
# ⚠️  NUNCA commite o arquivo .env no Git!
# ============================================

# Banco de dados (PostgreSQL - Supabase)
# Obtenha em: Supabase > Settings > Database > Connection string > Transaction pooler (porta 6543)
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Senha padrão para os usuários criados pelo seed (admin, maria, joao, ana, carlos)
# Defina uma senha segura antes de rodar: npx prisma db seed
SEED_PASSWORD=sua_senha_segura_aqui
